{
  "info": {
    "name": "CivicPulse Nexus - Milestone 2 Service Management",
    "description": "Certificate and permit application workflow APIs. Set bearerToken, citizenId, officerId, and applicationId before running requests.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080/api" },
    { "key": "bearerToken", "value": "" },
    { "key": "citizenId", "value": "1" },
    { "key": "officerId", "value": "2" },
    { "key": "applicationId", "value": "1" }
  ],
  "item": [
    {
      "name": "Citizen APIs",
      "item": [
        {
          "name": "Apply for Certificate or Permit",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{bearerToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"citizenId\": {{citizenId}},\n  \"serviceType\": \"INCOME_CERTIFICATE\",\n  \"applicantName\": \"Citizen User\",\n  \"aadhaarNumber\": \"123456789012\"\n}"
            },
            "url": "{{baseUrl}}/services/apply"
          }
        },
        {
          "name": "My Applications",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{bearerToken}}" }],
            "url": "{{baseUrl}}/services/citizen/{{citizenId}}"
          }
        },
        {
          "name": "Get Application Details",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{bearerToken}}" }],
            "url": "{{baseUrl}}/services/{{applicationId}}"
          }
        },
        {
          "name": "Upload Supporting Document",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{bearerToken}}" }],
            "body": {
              "mode": "formdata",
              "formdata": [{ "key": "file", "type": "file", "src": [] }]
            },
            "url": "{{baseUrl}}/services/{{applicationId}}/documents"
          }
        },
        {
          "name": "Download Certificate PDF",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{bearerToken}}" }],
            "url": "{{baseUrl}}/services/download/{{applicationId}}"
          }
        }
      ]
    },
    {
      "name": "Officer APIs",
      "item": [
        {
          "name": "View Pending Applications",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{bearerToken}}" }],
            "url": "{{baseUrl}}/services/pending"
          }
        },
        {
          "name": "Verify Documents",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{bearerToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"officerId\": {{officerId}},\n  \"verified\": true\n}" },
            "url": "{{baseUrl}}/services/verify/{{applicationId}}"
          }
        },
        {
          "name": "Approve Application",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{bearerToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"officerId\": {{officerId}},\n  \"verified\": true\n}" },
            "url": "{{baseUrl}}/services/approve/{{applicationId}}"
          }
        },
        {
          "name": "Reject Application",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{bearerToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"officerId\": {{officerId}},\n  \"reason\": \"Supporting document is incomplete\"\n}" },
            "url": "{{baseUrl}}/services/reject/{{applicationId}}"
          }
        },
        {
          "name": "Generate Certificate",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Authorization", "value": "Bearer {{bearerToken}}" }],
            "url": "{{baseUrl}}/services/{{applicationId}}/certificate/generate"
          }
        }
      ]
    },
    {
      "name": "Admin APIs",
      "item": [
        {
          "name": "All Applications",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{bearerToken}}" }],
            "url": "{{baseUrl}}/services"
          }
        },
        {
          "name": "Applications by Status",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{bearerToken}}" }],
            "url": "{{baseUrl}}/services/status/CERTIFICATE_GENERATED"
          }
        },
        {
          "name": "Applications by Service Type",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{bearerToken}}" }],
            "url": "{{baseUrl}}/services/type/INCOME_CERTIFICATE"
          }
        }
      ]
    }
  ]
}
